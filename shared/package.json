{
  "name": "@mindproject/shared",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles/index.css",
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "scripts": {
    "build": "tsc && npm run pre-render && node -e \"const fs=require('fs');const path=require('path');fs.mkdirSync(path.join('dist','styles'),{recursive:true});fs.copyFileSync(path.join('src','styles','index.css'),path.join('dist','styles','index.css'));\"",
    "build:copy": "tsc && node -e \"const fs=require('fs');const path=require('path');fs.mkdirSync(path.join('dist','styles'),{recursive:true});fs.copyFileSync(path.join('src','styles','index.css'),path.join('dist','styles','index.css'));\"",
    "dev": "tsc --watch",
    "pre-render": "node scripts/pre-render.js"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "next": ">=14.0.0",
    "lucide-react": "^0.400.0",
    "framer-motion": "^12.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "next": "^16.2.5",
    "lucide-react": "^0.400.0",
    "framer-motion": "^12.0.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.0"
  }
}